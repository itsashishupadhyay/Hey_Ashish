.cache/
.parcel-cache/
.sass-cache/
*.css.map
*.js.map

# Environment & secrets
.env
.env.local
.env.*.local

# Logs
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# OS files
.DS_Store
Thumbs.db
Desktop.ini

# Editor / IDE
.idea/
.vscode/
*.swp
*.swo
*~
.project
.settings/
.claude/

# Temp files
tmp/
temp/
*.tmp
*.bak
*.orig